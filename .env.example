# Facebook Ads Pro MCP Server — Environment Variables
# Copy this file to .env and fill in your values

# Required: Facebook / Meta access token
# Get it from: https://developers.facebook.com/tools/explorer/
# Needs permissions: ads_read, ads_management, business_management
FACEBOOK_ACCESS_TOKEN=your_access_token_here

# Optional: Default ad account ID (used as fallback when not passed per-request)
# Format: act_XXXXXXXXXXXXXXXXX
FACEBOOK_AD_ACCOUNT_ID=act_your_account_id_here
